# API Configuration
API_HOST=0.0.0.0
API_PORT=8080
DEBUG=False
ALLOWED_ORIGINS=*

# Authentication (comma-separated API keys)
API_KEYS=your-secret-key-1,your-secret-key-2

# Rate Limiting
RATE_LIMIT_PER_MINUTE=10

# vLLM Configuration
VLLM_URL=http://localhost:8000/v1
MODEL_NAME=Qwen/Qwen2.5-7B-Instruct
MAX_TOKENS=2048
TEMPERATURE=0.7

# Monitoring
ENABLE_METRICS=True
